{
  "rules": [
    {
      "allowed": {
        "origins": [
          "http://localhost:3000",
          "http://127.0.0.1:3000",
          "https://cloudflare-r2-presentation.vercel.app"
        ],
        "methods": ["GET", "PUT", "HEAD", "DELETE"],
        "headers": ["Content-Type"]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
